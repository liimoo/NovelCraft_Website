# WordPress設定ファイル（DBパスワード等が含まれるためgit管理外）
wp-config.php

# アップロードされたメディアファイル（容量が大きいためgit管理外）
wp-content/uploads/

# キャッシュ・一時ファイル
wp-content/cache/
wp-content/upgrade/
wp-content/backup-db/

# ログ
*.log
error_log

# macOS
.DS_Store

# FTP認証情報（絶対にgit管理しない）
.ftpconfig

# WordPress REST API認証情報（絶対にgit管理しない）
.wpconfig

# サーバー設定（サーバー側で管理）
.htaccess
